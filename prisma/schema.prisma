generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String           @id @default(uuid())
  name            String
  email           String           @unique
  password        String
  role            Role
  status          String           @default("ACTIVE")
  meals           Meal[]
  orders          Order[]
  providerProfile ProviderProfile?
  reviews         Review[]
  wishlists       Wishlist[]
}

model ProviderProfile {
  id      String  @id @default(uuid())
  bio     String?
  address String?
  phone   String?
  userId  String  @unique
  user    User    @relation(fields: [userId], references: [id])
}

model Category {
  id    String @id @default(uuid())
  name  String @unique
  meals Meal[]
}

model Meal {
  id          String      @id @default(uuid())
  name        String
  price       Float
  description String
  image       String
  providerId  String
  categoryId  String
  category    Category    @relation(fields: [categoryId], references: [id])
  provider    User        @relation(fields: [providerId], references: [id])
  orderItems  OrderItem[]
  reviews     Review[]
  wishlists   Wishlist[]
}

model Order {
  id         String      @id @default(uuid())
  status     OrderStatus @default(PLACED)
  address    String
  totalPrice Float       @default(0)
  createdAt  DateTime    @default(now())
  userId     String
  user       User        @relation(fields: [userId], references: [id])
  items      OrderItem[]
}

model OrderItem {
  id       String @id @default(uuid())
  quantity Int
  price    Float
  orderId  String
  mealId   String
  meal     Meal   @relation(fields: [mealId], references: [id])
  order    Order  @relation(fields: [orderId], references: [id])
}

model Review {
  id      String @id @default(uuid())
  rating  Int
  comment String
  userId  String
  mealId  String
  meal    Meal   @relation(fields: [mealId], references: [id])
  user    User   @relation(fields: [userId], references: [id])
}

model FoodImage {
  id          String   @id @default(uuid())
  url         String
  title       String
  description String?
  createdAt   DateTime @default(now())
}

model Wishlist {
  id        String   @id @default(uuid())
  userId    String
  mealId    String
  createdAt DateTime @default(now())
  meal      Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mealId])
}

model Coupon {
  id           String       @id @default(uuid())
  code         String       @unique
  discountType DiscountType
  value        Float
  isActive     Boolean      @default(true)
  expiry       DateTime?
  createdAt    DateTime     @default(now())
}

enum Role {
  CUSTOMER
  PROVIDER
  ADMIN
}

enum OrderStatus {
  PLACED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  FIXED
}
